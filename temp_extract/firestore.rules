rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vouchers
    // Fields:
    //   - type: string (required, enum: Receipt, Payment, Sales, Purchase, General)
    //   - number: string (required)
    //   - date: string (required, ISO 8601)
    //   - description: string (required)
    //   - totalAmount: number (required)
    //   - items: list (required)
    //   - createdBy: string (required, UID)
    //   - status: string (optional, enum: PendingApproval, Approved, Rejected, Posted)
    //   - approvedBy: string (optional, UID)
    //   - approvedAt: timestamp (optional)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (optional, enum: admin, accountant, viewer)
    //   - workingYear: number (required)
    //   - workingMonth: number (required)
    //   - employeeId: string (optional)
    //   - employeeCode: string (optional)
    //   - department: string (optional)
    //   - position: string (optional)
    //   - phone: string (optional)
    //   - employeeName: string (optional)
    //
    // Collection: login_logs
    // Fields:
    //   - userId: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - workingMonth: number (required)
    //   - workingYear: number (required)
    //   - timestamp: timestamp (required)
    //   - userAgent: string (optional)
    //   - ipAddress: string (optional)
    //
    // Collection: products
    // Fields:
    //   - code: string (required)
    //   - name: string (required)
    //   - unit: string (required)
    //   - type: string (required, enum: Goods, Service, Material, Product)
    //   - openingQty: number (optional)
    //   - openingValue: number (optional)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' ||
         request.auth.token.email == "ngviphuc@gmail.com");
    }

    function isAccountant() {
      return isAuthenticated() && 
        (getUserData().role == 'accountant' || isAdmin());
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /opening_balances/{balanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /fixed_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.createdBy == request.auth.uid &&
                      (request.resource.data.status == 'PendingApproval' || !('status' in request.resource.data));
      allow update: if isAuthenticated() && (
                      // Admin/Accountant can update status or anything
                      isAccountant() ||
                      // Owner can update if it's currently PendingApproval or Rejected
                      (resource.data.createdBy == request.auth.uid && 
                       (resource.data.status == 'PendingApproval' || resource.data.status == 'Rejected') &&
                       // Owner can only set status back to PendingApproval (resubmit)
                       (request.resource.data.status == 'PendingApproval'))
                    );
      allow delete: if isAdmin() || (resource.data.createdBy == request.auth.uid && (resource.data.status == 'PendingApproval' || resource.data.status == 'Rejected'));
    }

    match /settings/company {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /partners/{partnerId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /periods/{periodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /login_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
